# Leave GCP_PROJECT_ID blank to reuse the active gcloud config project.
GCLOUD_BIN=/Users/anthonywu/google-cloud-sdk/bin/gcloud

GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_ARTIFACT_REGION=us-central1
GCP_SCHEDULER_REGION=us-central1

AR_REPOSITORY=gmail-genie
IMAGE_NAME=gmail-genie
IMAGE_TAG=latest

CLOUD_RUN_JOB_NAME=gmail-genie
CLOUD_RUN_JOB_CPU=1
CLOUD_RUN_JOB_MEMORY=512Mi
CLOUD_RUN_JOB_TASKS=1
CLOUD_RUN_JOB_MAX_RETRIES=0
CLOUD_RUN_JOB_TASK_TIMEOUT=900s

RUNTIME_SERVICE_ACCOUNT_ID=gmail-genie-job
SCHEDULER_SERVICE_ACCOUNT_ID=gmail-genie-scheduler

SCHEDULER_DAYTIME_JOB_NAME=gmail-genie-every-15m
SCHEDULER_DAYTIME_CRON="*/15 8-22 * * *"
SCHEDULER_OVERNIGHT_JOB_NAME=gmail-genie-every-2h-overnight
SCHEDULER_OVERNIGHT_CRON="0 23,1,3,5,7 * * *"
SCHEDULER_TIME_ZONE=America/Los_Angeles
SCHEDULER_OAUTH_TOKEN_SCOPE=https://www.googleapis.com/auth/cloud-platform

SECRET_GMAIL_CREDENTIALS_JSON=gmail-genie-credentials-json
SECRET_GMAIL_TOKEN_PICKLE=gmail-genie-token-pickle
SECRET_GMAIL_RULES_JSON=gmail-genie-rules-json
SECRET_TAILSCALE_AUTHKEY=gmail-genie-tailscale-authkey

LOCAL_GMAIL_CREDENTIALS_JSON=$HOME/.config/gmail-genie/credentials.json
LOCAL_GMAIL_TOKEN_PICKLE=$HOME/.config/gmail-genie/token.pickle
LOCAL_GMAIL_RULES_JSON=$HOME/.config/gmail-genie/rules.json

# Optional local source used to sync the Tailscale key into Secret Manager.
# The Cloud Run job reads the key from a mounted secret file, not from env vars.
TAILSCALE_AUTHKEY=

# Tailnet service IPs (optional). Find these with: tailscale status
# Format: TAILNET_SERVICE_NAME=100.x.x.x
# Example for LLM API running on a tailnet machine:
# TAILNET_LLM_API_IP=100.81.183.108

NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=

LOG_LIMIT=50
